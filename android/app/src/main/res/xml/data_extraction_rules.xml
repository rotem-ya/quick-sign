<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+: same policy for cloud backup and device transfer. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="sharedpref" path="."/>
        <exclude domain="cache" path="."/>
    </cloud-backup>
    <device-transfer>
        <include domain="sharedpref" path="."/>
        <exclude domain="cache" path="."/>
    </device-transfer>
</data-extraction-rules>
